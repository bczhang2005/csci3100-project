<%= form_with(model: item, local: true) do |form| %>
  <div class="form-body">
    <% if item.errors.any? %>
      <div id="error_explanation">
      <h2><%= pluralize(item.errors.count, "error") %> prohibited this item from being saved:</h2>
      <ul>
        <% item.errors.full_messages.each do |message| %>
        <li><%= message %></li>
        <% end %>
      </ul>
      </div>
    <% end %>

    <div class="form-group">
      <%= form.label :name, class: "form-label" %>
      <%= form.text_field :name, class: "form-control", required: true %>
    </div>

    <div class="form-group">
      <%= form.label :description, class: "form-label" %>
      <%= form.text_area :description, class: "form-control", required: true %>
    </div>

    <div class="form-row">
      <div class="form-group">
        <%= form.label :category, class: "form-label" %>
        <%= form.select :category, 
          options_for_select([
            ["Electronics", "electronics"],
            ["Furniture", "furniture"],
            ["Clothing", "clothing"],
            ["Books", "books"],
            ["Sports", "sports"],
            ["Other", "other"]
            ], item.category),
            { include_blank: "Select a category" },
            { class: "form-select", required: true } %>
        </div>

        <div class="form-group">
          <%= form.label :price, class: "form-label" %>
          <%= form.number_field :price, step: 1, class: "form-control", required: true %>
        </div>
    </div>

    <div class="form-group">
      <label class="form-label">Item image</label>
      <div class="form-text">Demo mode uses a fixed image based on the item name or category, so no upload is needed here.</div>
    </div>

    <div class="form-btn-container">
      <%= form.submit "Post item", class: "btn-new left" %>
      <%= link_to "← Back to Market", items_path, class:"btn-new right" %>
    </div>
  </div>
<% end %>
