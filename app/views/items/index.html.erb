<div class="head-title">
  <div>
    <h1>Marketplace</h1>
    <p>Discover trusted second-hand deals from the CUHK community.</p>
  </div>

  <div class="market-summary">
    <div class="summary-chip">
      <span class="summary-label">Items Listed</span>
      <strong><%= @items.count %></strong>
    </div>
    <div class="summary-chip">
      <span class="summary-label">Campus Scope</span>
      <strong>CUHK Only</strong>
    </div>
  <div class="user-actions">
    <p style="font-size: 1.25rem; font-weight: 600; margin-right:40px"> Hello <%= @user&.name || "CUHK User" %>! </p>
    <div class="dropdown">
      <% if current_user.present? %>
        <%= link_to "👤 View My Profile", user_path(current_user), class: "dropdown-link" %>
      <% end %>
      <%= link_to "🚪 Log Out", logout_path, data: { turbo_method: :delete }, class: "dropdown-link logout" %>
    </div>
  </div>
</div>
</div> 
    
<section class="market-toolbar">
  <%= form_with url: items_path, method: :get, local: true, class: "filter-form" do %>
    <div class="filter-grid">
      <div class="filter-field filter-field-wide">
        <label for="keyword">Search</label>
        <%= text_field_tag :keyword, params[:keyword], id: "keyword", class: "filter-input", placeholder: "Search by item name, keyword or seller", list: "item-name-suggestions" %>
        <datalist id="item-name-suggestions">
          <% @autocomplete_suggestions.each do |suggestion| %>
            <option value="<%= suggestion %>"></option>
          <% end %>
        </datalist>
      </div>

      <div class="filter-field">
        <label for="category">Category</label>
        <%= select_tag :category,
          options_for_select([
            ["All categories", ""],
            ["Electronics", "electronics"],
            ["Furniture", "furniture"],
            ["Clothing", "clothing"],
            ["Books", "books"],
            ["Sports", "sports"],
            ["Other", "other"]
          ], params[:category]),
          id: "category",
          class: "filter-select" %>
      </div>

      <div class="filter-field">
        <label for="status">Status</label>
        <%= select_tag :status,
          options_for_select([
            ["Any status", ""],
            ["Available", "available"],
            ["Reserved", "reserved"],
            ["Sold", "sold"]
          ], params[:status]),
          id: "status",
          class: "filter-select" %>
      </div>

      <div class="filter-field">
        <label for="seller_location">Community</label>
        <%= select_tag :seller_location,
          options_for_select(
            [["All communities", ""]] + @seller_locations.map { |location| [location.titleize, location] },
            params[:seller_location]
          ),
          id: "seller_location",
          class: "filter-select" %>
      </div>

      <div class="filter-field">
        <label for="min_price">Min Price</label>
        <%= number_field_tag :min_price, params[:min_price], id: "min_price", class: "filter-input", placeholder: "0", min: 0 %>
      </div>

      <div class="filter-field">
        <label for="max_price">Max Price</label>
        <%= number_field_tag :max_price, params[:max_price], id: "max_price", class: "filter-input", placeholder: "5000", min: 0 %>
      </div>

      <div class="filter-field">
        <label for="posted_within_days">Posted Within</label>
        <%= select_tag :posted_within_days,
          options_for_select([
            ["Any time", ""],
            ["Last 3 days", "3"],
            ["Last 7 days", "7"],
            ["Last 30 days", "30"]
          ], params[:posted_within_days]),
          id: "posted_within_days",
          class: "filter-select" %>
      </div>

      <div class="filter-field">
        <label for="sort">Sort By</label>
        <%= select_tag :sort,
          options_for_select([
            ["Most relevant", "relevance"],
            ["Newest first", "newest"],
            ["Oldest first", "oldest"],
            ["Price: low to high", "price_low_to_high"],
            ["Price: high to low", "price_high_to_low"]
          ], params[:sort].presence || (params[:keyword].present? ? "relevance" : "newest")),
          id: "sort",
          class: "filter-select" %>
      </div>
    </div>

    <div class="quick-filters">
      <span class="quick-filters-label">Popular filters</span>
      <button class="quick-filter-pill" type="button">Under $100</button>
      <button class="quick-filter-pill" type="button">Available Now</button>
      <button class="quick-filter-pill" type="button">Books & Notes</button>
      <button class="quick-filter-pill" type="button">Dorm Pick-up</button>
    </div>

    <div class="filter-actions">
      <%= submit_tag "Search items", class: "btn-new toolbar-btn" %>
      <%= link_to "Clear filters", items_path, class: "btn-secondary" %>
    </div>
  <% end %>
</section>

<p class="search-result-summary">
  Showing <strong><%= @items.count %></strong> result(s)
</p>

<div class="items-grid" id="items-grid">
  <% @items.each do |item| %>
    <div class="item-card" data-item-id="<%= item.id %>" data-category="<%= item.category %>" data-name="<%= item.name.downcase %>">
      <div class="card-head">
        <div class="card-checkbox">
          <input type="checkbox" class="item-checkbox" value="<%= item.id %>">
        </div>
        <div class="card-badge">
          <%= item.category %>
        </div>
      </div>

        <div class="card-content">
          <h3 class="card-title"><%= item.name %></h3>
          <p class="card-description"><%= truncate(item.description, length: 50) %></p>
          <div class="card-price">$<%= item.price %></div>
          <div class="item-status-badge">
            <%= item.status.presence || "available" %>
          </div>
          <div class="card-meta">
            <div class="seller-info">
              <span><%= item.seller.name || "Unknown" %></span>
            </div>
            <div>
            <%= item.seller.location.presence || "CUHK" %>
          </div>
            <div>
            📅 <%= item.post_date %>
          </div>
        </div>
        <div class="card-link">
          <%= link_to "more info ->", item %>
        </div>
      </div>
    </div>
  <% end %>
</div>

<div class="market-action-row">
  <%= link_to "Post my own item", new_item_path, class: "btn-new" %>
</div>
