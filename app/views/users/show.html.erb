<div class="item-detail-container">
  <div class="item-card-detail">
    <!-- Added style to center content and restrict width for better readability -->
    <div class="item-layout" style="max-width: 800px; margin: 0 auto;">
      
      <div class="info-section">
        
        <!-- Visual Header: Replaces the image column -->
        <div style="text-align: center; margin-bottom: 2rem;">
          <div style="
            width: 100px; 
            height: 100px; 
            background-color: #f3f4f6; 
            border-radius: 50%; 
            display: flex; 
            align-items: center; 
            justify-content: center; 
            margin: 0 auto 1rem auto;
            font-size: 2.5rem;
            color: #4b5563;
            font-weight: bold;
          ">
            <%= @user.name&.first || "U" %>
          </div>
          <!-- Name -->
          <h1 class="item-name" style="margin-bottom: 0.5rem;"><%= @user.name %></h1>
          <p style="color: #6b7280;">Member Profile</p>
        </div>

        <hr style="border: 0; border-top: 1px solid #e5e7eb; margin: 2rem 0;">

        <!-- Location -->
        <div class="meta-info">
          <div class="meta-item">
            <div class="meta-icon">📍</div>
            <div>
              <div class="meta-label">Location</div>
              <div class="meta-value"><%= @user.location.present? ? @user.location : "Not specified" %></div>
            </div>
          </div>
        </div>

        <!-- Email -->
        <div class="meta-info">
          <div class="meta-item">
            <div class="meta-icon">✉️</div>
            <div>
              <div class="meta-label">Email Address</div>
              <div class="meta-value"><%= @user.email %></div>
            </div>
          </div>
        </div>

        <!-- Password Status -->
        <div class="seller-card">
          <div class="seller-info">
            <h4>🔐 Security Status</h4>
            <p>
              Password is 
              <strong><%= @user.password_digest.present? ? "Set" : "Not Set" %></strong>
            </p>
          </div>
        </div>

      </div>
    </div>
  </div>

  <!-- Action Buttons -->
  <div class="item-btn-container">
    <div class="item-btn-dummy"></div>
    <%= link_to "Edit Profile", edit_user_path(@user), class: "btn-new item-btn" %>
    <%= link_to "← Back to Market", items_path, class: "btn-new item-btn" %>
    <div class="item-btn-dummy"></div>
  </div>
</div>