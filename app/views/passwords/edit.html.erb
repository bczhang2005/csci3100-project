<h1>Enter Verification Code</h1>
<p>We've sent a 6-digit code to your email.</p>
<%= form_with(url: password_path(params[:user_id]), local: true, method: :patch) do |form| %>
  <div class="form-group">
    <%= form.label :code, "Verification Code", class: "form-label" %>
    <%= form.text_field :code, class: "form-control", placeholder: "123456", required: true %>
  </div>
  <%= form.submit "Verify Code", class: "btn-new" %>
<% end %>
